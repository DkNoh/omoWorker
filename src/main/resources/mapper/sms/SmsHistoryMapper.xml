<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbk.sms.mapper.sms.SmsHistoryMapper">

    <!-- Scaffold 생성(v1). 생성 후 개발자가 직접 수정해 소유한다. -->
    <!-- 화면 DatePicker 검색값은 YYYYMMDD 문자열로 전달된다 (TuiPageBuilder 규약).
         비교 컬럼이 DATE/TIMESTAMP면 TO_DATE/TO_TIMESTAMP로 감싸고,
         단일 날짜 = 조건은 당일 00:00:00 이상, 다음날 00:00:00 미만 범위로 변환한다. -->

    <sql id="searchConditions">
        <where>
            <if test="sendType != null and sendType != ''">
                AND A.SEND_TYPE = #{sendType}
            </if>
            <if test="sendStatus != null and sendStatus != ''">
                AND A.SEND_STATUS = #{sendStatus}
            </if>
            <if test="sentAt != null and sentAt != ''">
                AND A.SENT_AT <![CDATA[ >= ]]> TO_TIMESTAMP(#{sentAt} || '000000', 'YYYYMMDDHH24MISS') AND A.SENT_AT <![CDATA[ < ]]> TO_TIMESTAMP(#{sentAt} || '000000', 'YYYYMMDDHH24MISS') + INTERVAL '1' DAY
            </if>
            <if test="receiverNo != null and receiverNo != ''">
                AND A.RECEIVER_NO LIKE '%' || #{receiverNo} || '%'
            </if>
        </where>
    </sql>

    <sql id="baseQuery">
            SELECT
                     A.SMS_HISTORY_ID AS SMS_HISTORY_ID,
                     A.REQUEST_ID AS REQUEST_ID,
                     A.SENT_AT AS SENT_AT,
                     A.RECEIVER_NO AS RECEIVER_NO,
                     A.SENDER_NO AS SENDER_NO,
                     A.SEND_TYPE AS SEND_TYPE,
                     A.SEND_STATUS AS SEND_STATUS,
                     A.RESULT_CD AS RESULT_CD,
                     A.RESULT_MSG AS RESULT_MSG
                 FROM SMS.SMS_HISTORY A
    </sql>

    <select id="count" resultType="int">
        /* SmsHistoryMapper.count */
        SELECT COUNT(1) FROM (
        <include refid="baseQuery"/>
        ) A
        <include refid="searchConditions"/>
    </select>

    <select id="selectList" resultType="com.scbk.sms.vo.sms.SmsHistoryVO">
        /* SmsHistoryMapper.selectList */
        SELECT A.*
        FROM (
        <include refid="baseQuery"/>
        ) A
        <include refid="searchConditions"/>
        ORDER BY A.SMS_HISTORY_ID
        OFFSET #{offset} ROWS FETCH NEXT #{size} ROWS ONLY
    </select>

</mapper>
